# ╔══════════════════════════════════════════════════════════╗
# ║  POIREAUT — Environment variables                        ║
# ║  Copy to .env and fill in. Never commit .env.            ║
# ╚══════════════════════════════════════════════════════════╝

# ───── App ─────
APP_ENV=development
LOG_LEVEL=INFO

# ───── API ─────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# ───── Auth ─────
# Generate a real secret for anything non-local:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production-please-seriously
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOW_REGISTRATION=true

# ───── Database ─────
DATABASE_URL=postgresql+asyncpg://poireaut:poireaut@postgres:5432/poireaut

# ───── Redis / Celery ─────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ───── Frontend (Vite) ─────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ───── OSINT tool credentials (fill when needed) ─────
HIBP_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=
